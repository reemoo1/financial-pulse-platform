# مهم: ضعي نفس DATABASE_URL في بوابة الشركات وبوابة البنك حتى تظهر الطلبات والقرارات في الجهتين.
DATABASE_URL=
POSTGRES_SSL_MODE=require
POSTGRES_SSL_CA=

# مفتاح جلسات لا يقل عن 32 حرفًا. يمكن استخدام قيمة مختلفة لكل بوابة، لكن يفضل حفظها بأمان.
SESSION_SECRET=

# التخزين الدائم للمرفقات والرسائل عند استخدام PostgreSQL.
FILE_STORAGE=database
OUTBOX_STORAGE=database
ALLOW_EPHEMERAL_FILE_STORAGE=false
ALLOW_LOCAL_STORE_IN_PRODUCTION=false

# اختياري: إنشاء الشروحات النصية بالذكاء الاصطناعي.
OPENAI_API_KEY=

OTP_TTL_MINUTES=30
OTP_MAX_ATTEMPTS=3

PROVIDER_EMAIL=
SUPPLIER_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Financial Pulse <no-reply@financial-pulse.local>"
SMTP_EHLO_DOMAIN=financial-pulse.local
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=20000
SMTP_TLS_INSECURE=false
