# Optional: if set, AI narrative reports are generated via OpenAI.
# If left empty, the app falls back to deterministic Arabic report templates
# so the project runs fully offline out of the box.
OPENAI_API_KEY=

# Optional: connection string for a real PostgreSQL database (see database/schema.sql).
# If left empty, the app persists reports to a local JSON file (data/db.json) for demo purposes.
DATABASE_URL=
