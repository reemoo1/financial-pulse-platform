{
  "name": "financial-pulse-company-portal",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "npm run typecheck && next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:pipeline": "python -m src.elt.pipeline data/raw/financial_data.csv",
    "test:analysis": "node scripts/verify-analysis.mjs",
    "test": "vitest run",
    "test:unit": "vitest run tests/financial.test.ts",
    "test:parity": "vitest run tests/financial-parity.test.ts",
    "test:python": "python3 -m unittest discover -s tests/python -v"
  },
  "dependencies": {
    "csv-parse": "6.1.0",
    "fast-xml-parser": "5.9.3",
    "fflate": "0.8.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lowdb": "^7.0.1",
    "lucide-react": "^0.400.0",
    "next": "15.5.20",
    "nodemailer": "^9.0.3",
    "pdfjs-dist": "^4.10.38",
    "pg": "^8.13.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "^2.12.7",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.11.10",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.19",
    "postcss": "8.5.10",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  }
}
